/* 
  Комплексный тест возможностей языка.
  Если хоть одно утверждение ложно, программа упадет с паникой.
*/

функция тест_математики() : пусто {
    целое а = 10;
    целое б = 3;
    
    печать("1"); утверждение(а + б == 13);
    печать("2"); утверждение(а - б == 7);
    печать("3"); утверждение(а * б == 30);
    печать("4"); утверждение(а / б == 3); // Целочисленное деление
}

функция тест_логики() : пусто {
    лог истинно = истина;
    лог ложно = ложь;
    
    // В нашей реализации пока нет операторов && и ||, 
    // но мы можем проверить логику через ветвления
    целое флаг = 0;
    если (истинно) {
        печать("INSIDE IF"); флаг = 1;
    }
    печать("5"); печать(флаг); утверждение(флаг == 1);
}

функция фибоначчи(целое н) : целое {
    если (н < 2) {
        вернуть н;
    }
    вернуть фибоначчи(н - 1) + фибоначчи(н - 2);
}

функция тест_рекурсии() : пусто {
    // 0, 1, 1, 2, 3, 5, 8, 13
    печать("6"); печать(фибоначчи(7)); утверждение(фибоначчи(7) == 13);
}

функция Начало() : целое {
    тест_математики();
    тест_логики();
    тест_рекурсии();
    
    // Если мы дошли до сюда, значит ни один assert не упал
    печать("SELF-TEST PROPASSED!");
    вернуть 0;
}
