/*
  Переприсваивание массива целиком новым литералом (было статической ошибкой)
  и поэлементное/попольное сравнение ==/!= для массивов и структур
  (было сравнением адреса блока в Арене).
*/

структура Точка {
    целое х;
    целое у;
}

функция Начало() : целое {
    целое[3] a = [1, 2, 3];
    a = [4, 5, 6];               // переприсваивание массива целиком
    утверждение(a[0] == 4);
    утверждение(a[1] == 5);
    утверждение(a[2] == 6);

    целое[3] b = [4, 5, 6];      // структурно идентичен a, но отдельная память
    утверждение(a == b);         // поэлементное сравнение, а не по адресу
    b[0] = 9;
    утверждение(a != b);
    утверждение(!(a == b));

    Точка p1 = Точка{1, 2};
    Точка p2 = Точка{1, 2};
    утверждение(p1 == p2);       // попольное сравнение, а не по адресу
    p2.у = 3;
    утверждение(p1 != p2);

    Точка[2] pa1 = [Точка{1, 2}, Точка{3, 4}];
    Точка[2] pa2 = [Точка{1, 2}, Точка{3, 4}];
    утверждение(pa1 == pa2);     // вложенное сравнение: массив структур

    печать("ARRAY/STRUCT EQUALITY PASSED!");
    вернуть 0;
}
