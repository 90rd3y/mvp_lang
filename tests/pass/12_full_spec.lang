/*
  ФИНАЛЬНЫЙ ТЕСТ СПЕЦИФИКАЦИИ
  Проверяет все подсистемы: типы, структуры, массивы, функции, циклы и математику.
*/

// 1. Синонимы типов
тип Число = целое;

// 2. Структуры (с вложенностью)
структура Вектор {
    Число х;
    Число у;
}

структура Сущность {
    Вектор позиция;
    Число здоровье;
    лог жива;
}

// 3. Функции и рекурсия
функция модуль(Число н) : Число {
    если (н < 0) { вернуть 0 - н; }
    вернуть н;
}

функция дистанция(Вектор а, Вектор б) : Число {
    // Манхэттенская метрика для простоты
    вернуть модуль(а.х - б.х) + модуль(а.у - б.у);
}

// Точка входа
функция Начало() : целое {
    // 4. Инициализация сложных структур
    Сущность моб = Сущность { Вектор { 10, 20 }, 100, истина };
    Сущность игрок = Сущность { Вектор { 15, 25 }, 100, истина };

    // 5. Вызов функций с передачей структур
    Число расст = дистанция(моб.позиция, игрок.позиция);
    утверждение(расст == 10); // |10-15| + |20-25| = 5 + 5 = 10

    // 6. Массивы и управление потоком (break/continue)
    Число[5] урон = [10, 0, 20, 50, 0];

    Число и = 0;
    пока (и < 5) {
        если (урон[и] == 0) {
            и = и + 1;
            продолжить; // Пропускаем нулевой урон
        }

        моб.здоровье = моб.здоровье - урон[и];

        если (моб.здоровье <= 0) {
            моб.жива = ложь;
            прервать; // Выходим из цикла, если моб погиб
        }
        и = и + 1;
    }

    // 7. Проверка финального состояния
    утверждение(моб.здоровье == 20); // 100 - 10 - 20 - 50 = 20
    утверждение(моб.жива == истина);

    печать("=================================");
    печать("FULL SPECIFICATION TEST PROPASSED");
    печать("=================================");

    вернуть 0;
}
