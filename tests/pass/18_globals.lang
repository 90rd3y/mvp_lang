/*
  Глобальные переменные верхнего уровня: должны быть доступны на чтение
  и на запись из любой функции, включая запись из функции, вызванной
  из Начало (а не только напрямую в теле Начало).
*/

целое счётчик = 100;
строка метка = "исходная";

функция прочитать() : целое {
    вернуть счётчик;
}

функция увеличить() : пусто {
    счётчик = счётчик + 1;
    вернуть;
}

функция Начало() : целое {
    утверждение(счётчик == 100);
    утверждение(прочитать() == 100);

    увеличить();
    утверждение(счётчик == 101);
    утверждение(прочитать() == 101);

    счётчик = 200;
    утверждение(прочитать() == 200);

    утверждение(метка == "исходная");

    печать("GLOBALS PASSED!");
    вернуть 0;
}
