/*
  Интеграционный тест: Пузырьковая сортировка (Bubble Sort).
  Проверяет вложенные циклы, математику индексов и мутацию массивов.
*/

функция main() : целое {
    целое[5] м;
    
    // Инициализация массива вразнобой
    м[0] = 42;
    м[1] = 15;
    м[2] = 8;
    м[3] = 99;
    м[4] = 23;

    печать "--- До сортировки ---";
    целое к = 0;
    пока (к < 5) {
        печать м[к];
        к = к + 1;
    }

    // Алгоритм сортировки пузырьком
    целое и = 0;
    пока (и < 5) {
        целое й = 0;
        // Внутренний цикл идет до (4 - и), но для простоты напишем (4)
        // так как интерпретатор справится с лишними итерациями
        пока (й < 4) {
            если (м[й] > м[й + 1]) {
                // Обмен элементов (swap)
                целое темп = м[й];
                м[й] = м[й + 1];
                м[й + 1] = темп;
            }
            й = й + 1;
        }
        и = и + 1;
    }

    печать "--- После сортировки ---";
    к = 0;
    пока (к < 5) {
        печать м[к];
        к = к + 1;
    }

    // Жесткая проверка результатов через утверждения
    утверждение(м[0] == 8);
    утверждение(м[1] == 15);
    утверждение(м[2] == 23);
    утверждение(м[3] == 42);
    утверждение(м[4] == 99);

    печать "SORTING PROPASSED!";
    вернуть 0;
}
