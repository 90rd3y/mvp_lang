/*
  Интеграционный тест: Пузырьковая сортировка.
*/

функция Начало() : целое {
    // Строгая инициализация
    целое[5] м = [42, 15, 8, 99, 23];

    печать("--- До сортировки ---");
    целое к = 0;
    пока (к < 5) {
        печать(м[к]);
        к = к + 1;
    }

    целое и = 0;
    пока (и < 5) {
        целое й = 0;
        пока (й < 4) {
            если (м[й] > м[й + 1]) {
                целое темп = м[й];
                м[й] = м[й + 1];
                м[й + 1] = темп;
            }
            й = й + 1;
        }
        и = и + 1;
    }

    печать("--- После сортировки ---");
    к = 0;
    пока (к < 5) {
        печать(м[к]);
        к = к + 1;
    }

    утверждение(м[0] == 8);
    утверждение(м[1] == 15);
    утверждение(м[2] == 23);
    утверждение(м[3] == 42);
    утверждение(м[4] == 99);

    печать("SORTING PROPASSED!");
    вернуть 0;
}
