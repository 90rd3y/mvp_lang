структура Точка {
    целое х;
    целое у;
}

структура Игрок {
    Точка позиция;
    целое здоровье;
}

функция Начало() : целое {
    Точка нач_позиция = Точка { 15, 42 };
    Игрок герой = Игрок { нач_позиция, 100 };

    печать(герой.здоровье);
    печать(герой.позиция.х);
    печать(герой.позиция.у);

    утверждение(герой.здоровье == 100);
    утверждение(герой.позиция.х == 15);
    утверждение(герой.позиция.у == 42);

    целое сумма = герой.позиция.х + герой.позиция.у;
    утверждение(сумма == 57);

    печать("STRUCTS PASSED!");
    вернуть 0;
}
