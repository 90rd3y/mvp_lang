/*
  как<лог>(...) был статически разрешён, но в рантайме не делал реального
  преобразования (результат оставался исходным значением as-is). Также
  как<целое>/как<вещ> от лог всегда давали 0/0.0 независимо от значения.
*/

функция Начало() : целое {
    лог а = как<лог>(0);
    лог б = как<лог>(1);
    лог в = как<лог>(0.0);
    лог г = как<лог>(3.14);

    утверждение(а == ложь);
    утверждение(б == истина);
    утверждение(в == ложь);
    утверждение(г == истина);

    целое д = как<целое>(истина);
    целое е = как<целое>(ложь);
    утверждение(д == 1);
    утверждение(е == 0);

    вещ ж = как<вещ>(истина);
    вещ з = как<вещ>(ложь);
    утверждение(ж == 1.0);
    утверждение(з == 0.0);

    печать("CAST BOOL PASSED!");
    вернуть 0;
}
