/*
  Сравнение отрицательных "вещ" (было побитовым через .i64 — инвертировало
  порядок для двух отрицательных чисел) и оператор "%" (был вообще не
  реализован в рантайме и всегда давал 0).
*/

функция Начало() : целое {
    вещ а = -2.0;
    вещ б = -1.0;

    утверждение(а < б);
    утверждение(б > а);
    утверждение(а <= б);
    утверждение(б >= а);
    утверждение(!(а >= б));
    утверждение(!(б <= а));

    вещ в = -5.5;
    вещ г = -5.5;
    утверждение(в <= г);
    утверждение(в >= г);

    целое м1 = 10 % 3;
    утверждение(м1 == 1);
    целое м2 = 9 % 3;
    утверждение(м2 == 0);

    печать("FLOAT COMPARE & MODULO PASSED!");
    вернуть 0;
}
