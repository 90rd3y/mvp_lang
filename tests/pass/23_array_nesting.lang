/*
  Синонимы типов и функции с массивами в сигнатуре молча теряли размерность
  (параметр/возврат/алиас "целое[3]" типизировался как обычное "целое").
  Также поле структуры вида "целое[3] поле;" синтаксически парсилось, но
  семантический анализатор игнорировал размер массива.
*/

тип Тройка = целое[3];

структура Отрезок {
    целое[2] концы;
    целое длина;
}

функция сумма3(Тройка т) : целое {
    вернуть т[0] + т[1] + т[2];
}

функция сделать_тройку() : целое[3] {
    вернуть [7, 8, 9];
}

функция Начало() : целое {
    Тройка а = [1, 2, 3];
    утверждение(сумма3(а) == 6);

    целое[3] б = сделать_тройку();
    утверждение(б[0] == 7);
    утверждение(б[2] == 9);

    Отрезок о = Отрезок{[10, 20], 10};
    утверждение(о.концы[0] == 10);
    утверждение(о.концы[1] == 20);
    о.концы[0] = 99;
    утверждение(о.концы[0] == 99);

    печать("ARRAY NESTING PASSED!");
    вернуть 0;
}
