/*
  Проверка "все пути возврата дают значение" не учитывала While: тело функции
  с единственным "вернуть" внутри "пока(истина){...}" не проходило эту
  статическую проверку, хотя цикл гарантированно возвращает значение.
*/

функция найти_первое_чётное(целое старт) : целое {
    целое х = старт;
    пока (истина) {
        если (х % 2 == 0) {
            вернуть х;
        }
        х = х + 1;
    }
}

функция Начало() : целое {
    утверждение(найти_первое_чётное(7) == 8);
    утверждение(найти_первое_чётное(4) == 4);
    печать("WHILE-TRUE RETURN PASSED!");
    вернуть 0;
}
